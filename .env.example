# Required: Your Anthropic API key
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Optional: Override the AI model (default: claude-sonnet-4-20250514)
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Optional: Alpha access gate key (if set, users must enter this to access the app)
# Leave unset for local dev — gate is bypassed automatically when this is missing
# ALPHA_ACCESS_KEY=your-secret-key-here
